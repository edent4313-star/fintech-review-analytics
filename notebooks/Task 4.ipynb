        "        trend = latest_avg - earliest_avg\n",
        "        direction = '↑ Improving' if trend > 0 else '↓ Declining'\n",
        "        print(f'  {bank:8} → {direction:12} ({earliest_avg:.2f}★ → {latest_avg:.2f}★ = {trend:+.2f}★)')\n"
