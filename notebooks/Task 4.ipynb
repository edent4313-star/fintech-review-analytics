      "source": [
        "# Load all three banks\n",
        "dfs = {}\n",
        "bank_names = ['BOA', 'CBE', 'Dashen']\n",
        "file_paths = {\n",
        "    'BOA': 'fintech-review-analytics/data/raw/BOA_bank_reviews_clean_F.csv',\n",
        "    'CBE': 'fintech-review-analytics/data/raw/CBE_bank_reviews_clean_F.csv',\n",
        "    'Dashen': 'fintech-review-analytics/data/raw/Dashen_bank_reviews_clean_F.csv'\n",
        "}\n",
        "\n",
        "for bank, path in file_paths.items():\n",
        "    df_bank = pd.read_csv(path)\n",
        "    df_bank['bank'] = bank\n",
        "    df_bank['date'] = pd.to_datetime(df_bank['date'])\n",
        "    df_bank['month'] = df_bank['date'].dt.to_period('M')\n",
        "    df_bank['length'] = df_bank['review'].str.len()\n",
        "    df_bank['sentiment'] = df_bank['rating'].apply(\n",
        "        lambda r: 'Positive' if r >= 4 else ('Neutral' if r == 3 else 'Negative')\n",
        "    )\n",
        "    dfs[bank] = df_bank\n",
        "\n",
        "# Combine all banks\n",
        "df_all = pd.concat([dfs[bank] for bank in bank_names], ignore_index=True)\n",
        "\n",
        "print('✓ Loaded all three banks')\n",
        "print(f'\\nDataset Summary:')\n",
        "for bank in bank_names:\n",
        "    count = len(dfs[bank])\n",
        "    avg_rating = dfs[bank]['rating'].mean()\n",
        "    print(f'  {bank:8} → {count:4} reviews  |  Avg rating: {avg_rating:.2f}★')\n",
        "print(f'\\n  TOTAL    → {len(df_all):4} reviews')\n"
      ]
    },
