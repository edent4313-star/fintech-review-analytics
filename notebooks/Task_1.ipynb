        "import pandas as pd\n",
        "import nltk\n",
        "from nltk.sentiment.vader import SentimentIntensityAnalyzer\n",
        "# Ensure NLTK vader_lexicon is downloaded\n",
        "try:\n",
        "    nltk.data.find('sentiment/vader_lexicon.zip')\n",
        "except LookupError: # Correctly catch LookupError when resource is not found\n",
        "    nltk.download('vader_lexicon')\n",
        "\n",
        "analyzer = SentimentIntensityAnalyzer()\n",
        "\n",
        "# Add 'month' column to df\n",
        "df['month'] = pd.to_datetime(df['date']).dt.strftime('%B')\n",
        "\n",
        "# Add 'length' column to df\n",
        "df['length'] = df['review'].str.len()\n",
        "\n",
        "# Add 'sentiment' column based on VADER compound scores to df\n",
        "df['compound_score'] = df['review'].apply(lambda x: analyzer.polarity_scores(x)['compound'])\n",
        "df['sentiment'] = df['compound_score'].apply(\n",
        "    lambda score: 'Positive' if score >= 0.05 else ('Negative' if score <= -0.05 else 'Neutral')\n",
        ")\n",
        "\n",
        "# Select the desired columns in the right order to create df_clean\n",
        "df_clean = df[['review', 'rating', 'date', 'bank', 'source', 'month', 'length', 'sentiment']].copy()\n",
        "\n",
        "# Sort by date (newest first) for clean presentation\n",
        "df_clean = df_clean.sort_values('date', ascending=False).reset_index(drop=True)\n",
        "\n",
        "print(f\"Final dataset shape: {df_clean.shape}\")\n",
        "df_clean.head(10)"
      ]
    },
